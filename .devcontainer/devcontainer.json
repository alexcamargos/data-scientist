// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python Data Science Environment (Codespaces Optimized)",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"customizations": {
		"vscode": {
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python",
				"[python]": {
					"editor.defaultFormatter": "ms-python.black-formatter",
					"editor.formatOnSave": true,
					"editor.codeActionsOnSave": {
						"source.fixAll": "explicit",
						"source.organizeImports": "explicit"
					}
				},
				"isort.args": ["--profile", "black"],
				"isort.path": ["isort"],
				"terminal.integrated.defaultProfile.linux": "zsh",
				"terminal.integrated.profiles.linux": {
					"zsh": {
						"path": "/usr/bin/zsh"
					}
				}
			},
			"extensions": [
				"ms-python.python",
				"ms-toolsai.jupyter", // Essencial para Jupyter notebooks/lab no VS Code
				"ms-python.vscode-pylance",
				"ms-python.black-formatter", // Extensão oficial para o Black
				"ms-python.isort", // Extensão oficial para o isort
				"ms-python.flake8", // Extensão oficial para o flake8
				"ms-python.pylint", // Extensão oficial para o pylint
				"streetsidesoftware.code-spell-checker",
				"esbenp.prettier-vscode",
				"ms-vscode.live-server",
				"GitHub.copilot"
			]
		}
	},

	// Forward commonly used ports for web applications or Jupyter
	"forwardPorts": [8888, 5000, 8000],

	"portsAttributes": {
		"8888": {
			"label": "Jupyter Lab",
			"onAutoForward": "notify"
		},
		"5000": {
			"label": "Flask App",
			"onAutoForward": "notify"
		},
		"8000": {
			"label": "Custom App",
			"onAutoForward": "notify"
		}
	},

	// Run commands after the container is created
	"postCreateCommand": "pip install --no-cache-dir -r requirements.txt",

	// Connect as the vscode user, which is created by the base image
	"remoteUser": "vscode"
}
